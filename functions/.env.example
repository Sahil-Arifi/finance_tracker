# Set these in Firebase Functions runtime (Console → Functions → configuration) or Secret Manager.
# Do not commit real secrets.

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Receipt scan (scanReceipt): enable the Google Cloud Vision API on the same GCP project as Firebase
# (Google Cloud Console → APIs & Services → Library → “Cloud Vision API” → Enable). Billing must be on.

# Webhook URL after deploy: https://REGION-PROJECT.cloudfunctions.net/plaidWebhook
# Register in Plaid Dashboard → Webhooks.
