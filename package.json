{
  "name": "finance-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "firebase deploy --only functions",
    "cap:sync": "npx cap sync",
    "cap:build": "npm run build && npx cap sync",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win --publish never --dir"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@google/stitch-sdk": "^0.0.3",
    "firebase": "^12.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-plaid-link": "^4.1.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-tools": "^14.24.0",
    "globals": "^16.5.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.expensepilot.app",
    "productName": "ExpensePilot",
    "directories": {
      "output": "dist-electron-out4"
    },
    "toolsets": {
      "winCodeSign": null
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icons/icon-512.png",
      "signAndEditExecutable": false
    },
    "nsis": null
  }
}
