# =============================================================================
# FIREBASE SETUP (do these in order)
# =============================================================================
#
# 1) Web app config → fill this file
#    Firebase Console: Project overview (gear) → Project settings → Your apps
#    If you have no Web app yet: click "</>" (Add app) → register app → copy the
#    firebaseConfig object values into the variables below.
#
#    Map from firebaseConfig (VITE_ prefix + UPPER_SNAKE):
#      apiKey            → VITE_FIREBASE_API_KEY
#      authDomain        → VITE_FIREBASE_AUTH_DOMAIN
#      projectId         → VITE_FIREBASE_PROJECT_ID
#      storageBucket     → VITE_FIREBASE_STORAGE_BUCKET
#      messagingSenderId → VITE_FIREBASE_MESSAGING_SENDER_ID
#      appId             → VITE_FIREBASE_APP_ID
#
# 2) Authorized domains (for Google sign-in)
#    Authentication → Settings → Authorized domains
#    Add: localhost
#    After you deploy, add your real site domain too.
#
# 3) Deploy Firestore security rules (so only you can read your data)
#    In this project folder, in a terminal:
#      npm install
#      npx firebase login
#      npx firebase use --add    ← pick your Firebase project (creates .firebaserc)
#      npm run deploy:rules
#
# 4) Copy this file to .env (same folder as package.json), then run:
#      npm run dev
#
# =============================================================================
# NETLIFY (or any CI host)
# =============================================================================
#
# Vite reads VITE_* only when `npm run build` runs. Add these in the host’s
# environment UI (Netlify: Site configuration → Environment variables), using the
# exact names below. Redeploy after saving — a rebuild is required; editing vars
# alone does not change an already-built bundle.
#
# Also add your production domain under Firebase → Authentication → Authorized domains.
#
# =============================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region for Firebase Callable Functions (must match deployed functions region)
VITE_FUNCTIONS_REGION=us-central1

# -----------------------------------------------------------------------------
# APP CHECK (required if you turn ON enforcement in Firebase Console)
# -----------------------------------------------------------------------------
#
# If App Check enforcement is enabled for Auth, Firestore, or Cloud Functions,
# the web app must register App Check or every request is rejected.
#
# 1) Google reCAPTCHA v3: create a key at https://www.google.com/recaptcha/admin
#    (reCAPTCHA type: v3). Register your domains (e.g. localhost, production host).
#
# 2) Firebase Console → Build → App Check → your Web app → Register with
#    reCAPTCHA v3 and paste the same site key there.
#
# 3) Put the site key here and restart Vite:
#
# VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
#
# Local dev debug token (optional): first time, set VITE_APPCHECK_DEBUG=true,
# run the app, copy the token from the browser console, add it in App Check →
# Manage debug tokens, then set VITE_APPCHECK_DEBUG_TOKEN=<that-uuid> and remove
# VITE_APPCHECK_DEBUG.
#
# VITE_RECAPTCHA_SITE_KEY=
# VITE_APPCHECK_DEBUG=
# VITE_APPCHECK_DEBUG_TOKEN=
#
# Easiest path while building: set enforcement to OFF (or Monitor-only) for
# Auth / Firestore / Functions until these variables are set.
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# TROUBLESHOOTING: "401" in the browser Network tab right after sign-in
# -----------------------------------------------------------------------------
#
# 1) Cloud Run / Callable URL (*.run.app or similar)
#    Your app calls Cloud Functions right after login (e.g. Plaid link token).
#    Gen 2 functions need the HTTPS endpoint to allow invocation. In Google Cloud
#    Console → Cloud Run (same GCP project as Firebase) → open each function
#    service → Security / Permissions → allow unauthenticated invocations, or add
#    principal "allUsers" with role "Cloud Run Invoker". Redeploying with the
#    latest firebase-tools sometimes fixes this automatically.
#
# 2) identitytoolkit.googleapis.com
#    That is Firebase Auth. Re-copy all web config values from Firebase
#    Project settings → Your apps. In Google Cloud → APIs & Services →
#    Credentials, check the Browser API key: HTTP referrer restrictions must
#    include your dev origin (e.g. http://localhost:5173/*).
#
